---
import { getCollection, getEntry, render } from 'astro:content';
import Layout from '../layouts/Layout.astro';
import { sortByDateDesc } from '../utils/sorting';
import { formatDisplayDate } from '../utils/dates';

// When Awards is toggled off in the CMS (Site Settings), the page is hidden
// from the nav; a direct visit to /awards bounces to the home page so no one
// lands on an empty page.
const showAwards = (await getEntry('settings', 'settings'))?.data.showAwards ?? false;

const entries = showAwards
  ? sortByDateDesc(await getCollection('awards'), (e) => e.data.date)
  : [];
const rendered = await Promise.all(
  entries.map(async (entry) => ({ entry, Content: (await render(entry)).Content })),
);
---

{
  !showAwards && (
    <html lang="en">
      <head>
        <meta charset="utf-8" />
        <meta http-equiv="refresh" content="0; url=/" />
        <link rel="canonical" href="/" />
        <meta name="robots" content="noindex" />
        <title>Redirecting…</title>
      </head>
      <body>
        <p>
          This page isn’t available. <a href="/">Return home</a>.
        </p>
      </body>
    </html>
  )
}
{ showAwards && (

<Layout
  title="Awards | Vivan Bheda"
  description="Awards and recognition received by Vivan Bheda."
>
  <header class="page-header">
    <h1>Awards</h1>
    <p class="page-intro">Recognition and honors.</p>
  </header>
  {
    rendered.length > 0 ? (
      <ul class="card-list">
        {rendered.map(({ entry, Content }) => (
          <li class="card">
            <h2 class="card-title">{entry.data.title}</h2>
            <p class="card-sub">{entry.data.issuer}</p>
            <p class="card-meta">{formatDisplayDate(entry.data.date)}</p>
            {entry.data.description && <p class="card-sub">{entry.data.description}</p>}
            <div class="card-body">
              <Content />
            </div>
          </li>
        ))}
      </ul>
    ) : (
      <p class="empty-state">Nothing here yet.</p>
    )
  }
</Layout>
) }
