---
import '../styles/global.css';
import { getEntry } from 'astro:content';
import { hasValue } from '../utils/content';

interface Props {
  title: string;
  description?: string;
}

const {
  title,
  description = 'Portfolio of Vivan Bheda — computer science student building AI-powered web applications.',
} = Astro.props;

const navLinks = [
  { href: '/', label: 'Home' },
  { href: '/education', label: 'Education' },
  { href: '/projects', label: 'Projects' },
  { href: '/experiences', label: 'Experiences' },
  { href: '/certificates', label: 'Certificates' },
  { href: '/resume', label: 'Resume' },
  { href: '/skills', label: 'Skills' },
  { href: '/about', label: 'About' },
  { href: '/contact', label: 'Contact' },
  { href: '/awards', label: 'Awards' },
];

// Normalize the current path (strip trailing slash, except for the root)
// so active-link detection works in both dev and built output.
const currentPath = Astro.url.pathname.replace(/\/+$/, '') || '/';

// Footer links come from the contact singleton; any missing/blank value
// hides that link entirely instead of rendering a broken one.
const contact = (await getEntry('contact', 'contact'))?.data;
const linkedinUrl = contact?.linkedinUrl;
const githubUrl = contact?.githubUrl;
const email = contact?.email;

const footerLinks = [
  hasValue(linkedinUrl) ? { label: 'LinkedIn', href: linkedinUrl, external: true } : null,
  hasValue(githubUrl) ? { label: 'GitHub', href: githubUrl, external: true } : null,
  hasValue(email) ? { label: 'Email', href: `mailto:${email}`, external: false } : null,
].filter((link) => link !== null);
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:image" content="/og-image.png" />
    <meta name="twitter:card" content="summary_large_image" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600&family=Space+Grotesk:wght@500;600;700&display=swap"
      rel="stylesheet"
    />
  </head>
  <body>
    <a class="skip-link" href="#main">Skip to content</a>

    <header class="site-header">
      <div class="nav-inner">
        <a class="brand" href="/">Vivan Bheda</a>
        <nav aria-label="Main navigation">
          <ul class="nav-links" id="site-nav">
            {
              navLinks.map((link) => (
                <li>
                  <a
                    href={link.href}
                    aria-current={currentPath === link.href ? 'page' : undefined}
                  >
                    {link.label}
                  </a>
                </li>
              ))
            }
          </ul>
        </nav>
        <button
          class="nav-toggle"
          type="button"
          aria-expanded="false"
          aria-controls="site-nav"
          aria-label="Toggle navigation menu"
        >
          <span></span>
          <span></span>
          <span></span>
        </button>
      </div>
    </header>

    <main id="main">
      <slot />
    </main>

    <footer class="site-footer">
      <div class="footer-inner">
        <p>&copy; 2026 Vivan Bheda</p>
        {
          footerLinks.length > 0 && (
            <ul class="footer-links">
              {footerLinks.map((link) => (
                <li>
                  <a
                    href={link.href}
                    target={link.external ? '_blank' : undefined}
                    rel={link.external ? 'noopener noreferrer' : undefined}
                  >
                    {link.label}
                  </a>
                </li>
              ))}
            </ul>
          )
        }
      </div>
    </footer>

    <script>
      // Mobile nav toggle
      const header = document.querySelector('.site-header');
      const toggle = document.querySelector('.nav-toggle');
      if (header && toggle) {
        toggle.addEventListener('click', () => {
          const open = header.classList.toggle('menu-open');
          toggle.setAttribute('aria-expanded', String(open));
        });
      }

      // Scroll reveal: cards fade/slide in as they enter the viewport,
      // slightly staggered. JS adds the hidden state, so without JS (or
      // with prefers-reduced-motion) everything is simply visible.
      const reduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
      if (!reduced && 'IntersectionObserver' in window) {
        const targets = document.querySelectorAll<HTMLElement>('.card, .skill-group');
        const observer = new IntersectionObserver(
          (entries) => {
            for (const entry of entries) {
              if (!entry.isIntersecting) continue;
              const el = entry.target as HTMLElement;
              el.classList.add('revealed');
              observer.unobserve(el);
              // Clean up so the reveal transition/delay never interferes
              // with the card's own hover transitions afterward.
              window.setTimeout(() => {
                el.classList.remove('will-reveal', 'revealed');
                el.style.transitionDelay = '';
              }, 1000);
            }
          },
          { rootMargin: '0px 0px -40px 0px', threshold: 0.1 },
        );
        targets.forEach((el, index) => {
          el.classList.add('will-reveal');
          el.style.transitionDelay = `${(index % 5) * 70}ms`;
          observer.observe(el);
        });

        // Safety net: content must never stay hidden if the observer
        // stalls (throttled tabs, odd embedded contexts). After a few
        // seconds, anything not yet revealed simply becomes visible.
        window.setTimeout(() => {
          document.querySelectorAll<HTMLElement>('.will-reveal').forEach((el) => {
            observer.unobserve(el);
            el.classList.remove('will-reveal', 'revealed');
            el.style.transitionDelay = '';
          });
        }, 4000);
      }
    </script>
  </body>
</html>
